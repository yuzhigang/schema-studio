VITE_BASE_URL=http://localhost:3000

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# NOTE:
# In your Supabase Dashboard, set callback/redirect URIs to:
# http://localhost:3000/auth/v1/callback
#
# ------------------------------------------------------------------------------
# Cloudflare Pages Deployment
# ------------------------------------------------------------------------------
# Build command: cd apps/web && pnpm build
# Build output directory: apps/web/.output/public
# Root directory: apps/web
#
# Environment variables (set in Cloudflare Dashboard > Pages > Settings):
#   Production / Preview:
#     - SUPABASE_URL
#     - SUPABASE_SERVICE_ROLE_KEY
#     - VITE_SUPABASE_URL
#     - VITE_SUPABASE_ANON_KEY
#
# Or via CLI:
#   cd apps/web && wrangler pages secret put SUPABASE_URL
#
# Supabase OAuth callback URLs (configure in Supabase Dashboard > Authentication > URL Configuration):
#   Site URL: https://<your-project>.pages.dev
#   Redirect URLs: https://<your-project>.pages.dev/**
